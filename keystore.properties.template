# Copy this file to keystore.properties and fill in your own values.
# keystore.properties is gitignored (see .gitignore: keystore.properties / *.jks).
#
# storeFile: path relative to the project root (or absolute) pointing at the .jks
# storePassword / keyPassword: keystore + key passwords (often the same)
# keyAlias: alias used when creating the key with `keytool -genkeypair`
storeFile=keystore/pocketrdp-release.jks
storePassword=changeme
keyAlias=pocketrdp
keyPassword=changeme
