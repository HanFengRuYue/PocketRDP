    <string name="connection_fixed_frame_rate_desc">Limita la frecuencia de refresco; elige “Automático” si no estás seguro.</string>
    <string name="connection_default_input_mode">Modo de entrada predeterminado</string>
    <string name="connection_input_mode_trackpad">Ratón simulado</string>
    <string name="connection_input_mode_touch">Toque directo</string>
    <string name="connection_default_input_mode_desc">Ratón simulado usa un cursor virtual; toque directo envía puntos táctiles nativos. Puedes cambiar durante la sesión.</string>
    <string name="connection_h264_title">Activar aceleración de video H.264</string>
    <string name="connection_h264_desc">Comprime la pantalla remota para reducir tirones; al desactivarlo usa modo compatible.</string>
    <string name="connection_h264_tier">Calidad H.264</string>
    <string name="connection_quality_first">Priorizar calidad</string>
    <string name="connection_smooth_first">Priorizar fluidez</string>
    <string name="connection_h264_tier_desc">Fluidez reduce la latencia; calidad mantiene el texto más claro.</string>
    <string name="connection_gfx_title">Modo gráfico compatible</string>
    <string name="connection_gfx_desc">Solo se usa cuando la aceleración de video está desactivada.</string>
    <string name="connection_low_latency_visuals_title">Visuales de baja latencia</string>
    <string name="connection_low_latency_visuals_desc">Desactiva fondo y animaciones remotas para reducir latencia.</string>
    <string name="connection_dynamic_resolution_title">Resolución dinámica</string>
    <string name="connection_dynamic_resolution_desc">El tamaño remoto sigue la rotación y el cambio de tamaño</string>
    <string name="connection_dynamic_resolution_max">Límite de resolución dinámica</string>
    <string name="connection_follow_device">Seguir dispositivo</string>
    <string name="connection_dynamic_resolution_max_desc">Limita la resolución remota para reducir tirones.</string>
    <string name="connection_custom_resolution_title">Resolución personalizada fija</string>
    <string name="connection_custom_resolution_desc">Fija el lado remoto al ancho y alto elegidos. Desactiva la resolución dinámica.</string>
    <string name="connection_width">Ancho</string>
    <string name="connection_height">Alto</string>
    <string name="connection_multitransport_title">Multitransporte UDP</string>
    <string name="connection_multitransport_desc">Requiere que servidor y red permitan UDP en el mismo puerto; usa TCP si no está disponible.</string>
    <string name="connection_section_redirection">Redirección</string>
    <string name="connection_clipboard_title">Sincronización bidireccional del portapapeles</string>
    <string name="connection_clipboard_desc">Sincroniza texto copiado entre el teléfono y el PC. Las imágenes aún no son compatibles.</string>
    <string name="connection_files_title">Redirección de carpetas</string>
    <string name="connection_files_desc">Muestra el almacenamiento del teléfono como una unidad “PocketRDP” en el PC.</string>
