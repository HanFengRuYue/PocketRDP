    <string name="connection_h264_title">H.264 비디오 가속 사용</string>
    <string name="connection_h264_desc">원격 화면을 압축해 끊김을 줄입니다. 끄면 호환 모드를 사용합니다.</string>
    <string name="connection_h264_tier">H.264 화질 단계</string>
