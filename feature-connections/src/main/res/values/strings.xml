    <string name="connection_height">高度</string>
    <string name="connection_multitransport_title">UDP 多路传输</string>
    <string name="connection_multitransport_desc">需要服务器和网络允许同端口 UDP；不可用时自动回退 TCP。</string>
    <string name="connection_section_redirection">重定向</string>
    <string name="connection_clipboard_title">剪贴板双向同步</string>
    <string name="connection_clipboard_desc">手机与电脑间双向同步复制的文字（暂不支持图片）。</string>
    <string name="connection_files_title">文件夹重定向</string>
    <string name="connection_files_desc">把手机存储显示为电脑里的“PocketRDP”盘。</string>
    <string name="connection_files_permission_desc">需要先授予“所有文件访问”权限，否则连接时电脑端不会出现 PocketRDP 盘。</string>
    <string name="connection_files_permission_action">授予文件访问权限</string>
