    <string name="connection_default_input_mode_desc">模拟鼠标=虚拟光标；直接触屏=原生触摸点。会话内可随时切换。</string>
    <string name="connection_h264_title">启用 H.264 视频加速</string>
    <string name="connection_h264_desc">压缩远程画面，减少卡顿；关闭后使用兼容模式。</string>
    <string name="connection_h264_tier">H.264 画质档</string>
    <string name="connection_quality_first">画质优先</string>
    <string name="connection_smooth_first">流畅优先</string>
    <string name="connection_h264_tier_desc">流畅优先延迟更低；画质优先文字更清晰。</string>
    <string name="connection_gfx_title">兼容图形模式</string>
    <string name="connection_gfx_desc">仅在关闭视频加速时使用。</string>
    <string name="connection_low_latency_visuals_title">低延迟视觉</string>
    <string name="connection_low_latency_visuals_desc">关闭远端墙纸和动画，减少延迟。</string>
    <string name="connection_dynamic_resolution_title">动态分辨率</string>
    <string name="connection_dynamic_resolution_desc">屏幕旋转/拉伸时远端跟随调整</string>
    <string name="connection_dynamic_resolution_max">动态分辨率上限</string>
    <string name="connection_follow_device">跟随设备</string>
    <string name="connection_dynamic_resolution_max_desc">限制远端分辨率，降低卡顿。</string>
    <string name="connection_custom_resolution_title">固定自定义分辨率</string>
    <string name="connection_custom_resolution_desc">远端固定为指定宽高（将关闭动态分辨率）。</string>
